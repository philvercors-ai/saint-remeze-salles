# ── Django ──────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=changeme-generate-with-python-secrets
DEBUG=False
ALLOWED_HOSTS=salles.saint-remeze.fr,localhost
CORS_ALLOWED_ORIGINS=https://salles.saint-remeze.fr

# ── MongoDB ──────────────────────────────────────────────────────────────────
# Développement local (docker-compose) : mongodb://mongodb:27017/saint_remeze
# Production (MongoDB Atlas) : mongodb+srv://user:password@cluster.mongodb.net/saint_remeze
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/saint_remeze?retryWrites=true&w=majority
MONGODB_DB=saint_remeze

# ── Redis ────────────────────────────────────────────────────────────────────
# En local (docker-compose) : redis://redis:6379/0
# Sur Render : injecté automatiquement depuis le service Redis
REDIS_URL=redis://localhost:6379/0

# ── Emails (Resend) ──────────────────────────────────────────────────────────
# Créez un compte sur https://resend.com et obtenez votre clé API
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=Mairie de Saint-Rémèze <mairie@saint-remeze.fr>

# ── Frontend ─────────────────────────────────────────────────────────────────
# URL du backend (utilisée par le service worker et les redirections)
FRONTEND_URL=https://salles.saint-remeze.fr
# URL de l'API (variable Vite — build du frontend)
VITE_API_URL=https://saint-remeze-backend.onrender.com/api

# ── Générer une SECRET_KEY sécurisée ─────────────────────────────────────────
# python3 -c "import secrets; print(secrets.token_urlsafe(50))"
